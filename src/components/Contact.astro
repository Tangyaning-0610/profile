---
const contacts = [
  { label: '邮箱', value: 'your-email@example.com', href: 'mailto:your-email@example.com' },
  { label: 'GitHub', value: '@yourname', href: 'https://github.com/yourname' },
  { label: '微信', value: 'your-wechat-id', href: '#' },
];
---

<section id="contact" class="container">
  <h2 class="section-title">联系我</h2>
  <div class="contact-list">
    {contacts.map(item => (
      <a href={item.href} target="_blank" class="contact-card">
        <span class="contact-label">{item.label}</span>
        <span class="contact-value">{item.value}</span>
      </a>
    ))}
  </div>
</section>

<style>
  .contact-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
    max-width: 800px;
    margin: 0 auto;
  }
  .contact-card {
    padding: 24px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-align: center;
    transition: all 0.2s;
  }
  .contact-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .contact-label {
    display: block;
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 8px;
  }
  .contact-value {
    font-size: 1.05rem;
    font-weight: 500;
  }
</style>