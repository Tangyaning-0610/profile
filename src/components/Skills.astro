---
const skillGroups = [
  {
    title: '媒介运营',
    items: ['KOL/KOC达人投放', '品牌PR传播', '异业合作', '达人资源库搭建', '私域社群运营']
  },
  {
    title: '内容运营',
    items: ['小红书内容策划', '账号冷启动', '爆文打造', '店铺运营', '产品种草']
  },
  {
    title: '投放能力',
    items: ['千川投放', '随心推', '信息流广告', 'CPS推广', 'ROI优化']
  },
  {
    title: '行业经验',
    items: ['母婴品类', '电商玩具', '财经教育', '品牌服务', '知识付费']
  }
];
---

<section id="skills" style="background: white;">
  <div class="container">
    <h2 class="section-title">核心能力栈</h2>
    <div class="skills-grid">
      {skillGroups.map(group => (
        <div class="skill-group">
          <h3 class="group-title">{group.title}</h3>
          <div class="skill-items">
            {group.items.map(item => (
              <span class="skill-item">{item}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #skills {
    padding: 40px 0;
    margin: 40px 0;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
  }
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 32px;
  }
  .skill-group { padding: 24px; }
  .group-title {
    font-size: 1.1rem;
    margin-bottom: 16px;
    color: var(--accent);
    font-weight: 600;
  }
  .skill-items { display: flex; flex-wrap: wrap; gap: 10px; }
  .skill-item {
    padding: 6px 14px;
    background: var(--bg-primary);
    border-radius: 6px;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
</style>