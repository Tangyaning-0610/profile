---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

// 生成所有案例的静态路径
export async function getStaticPaths() {
  const works = await getCollection("works");
  return works.map((work) => ({
    params: { slug: work.id }, // 字符串 id 对应 [slug].astro
    props: { work },
  }));
}

const { work } = Astro.props;
// Astro v6 用全局 render 函数，不用 work.render()
const { Content } = await render(work);
---

<BaseLayout title={work.data.title} description={work.data.description}>
  <article class="work-detail container">
    <div class="detail-header">
      <span class="category-tag">{work.data.category}</span>
      <h1>{work.data.title}</h1>
      <div class="meta">
        <span>{work.data.date}</span>
        <span>·</span>
        <span>核心成果：{work.data.coreData}</span>
      </div>
    </div>

    <div class="highlights">
      <h3>项目亮点</h3>
      <ul>
        {work.data.highlight.map((item) => <li>{item}</li>)}
      </ul>
    </div>

    <!-- 嵌入 HTML 作品 -->
    {
      work.data.htmlWork && (
        <div class="html-work">
          <h3>作品预览</h3>
          <iframe
            src={work.data.htmlWork}
            title="作品预览"
            onload="autoResizeIframe(this)"
          />
        </div>
      )
    }

    <div class="markdown-content">
      <Content />
    </div>

    <div class="back-btn">
      <a href="/#works">← 返回案例列表</a>
    </div>
  </article>
</BaseLayout>

<style>
  .html-work iframe {
    width: 100%;
    min-height: 400px; /* 加载时的保底高度 */
    border: none;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    background: #fff;
  }
  .work-detail {
    padding: 60px 24px;
  }
  .detail-header {
    text-align: center;
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }
  .category-tag {
    display: inline-block;
    padding: 6px 16px;
    background: var(--accent-light);
    color: var(--accent);
    border-radius: 999px;
    font-size: 0.85rem;
    margin-bottom: 16px;
  }
  .detail-header h1 {
    font-size: 2.2rem;
    margin-bottom: 16px;
    line-height: 1.3;
    color: var(--text-primary);
  }
  .meta {
    color: var(--text-secondary);
  }
  .highlights {
    max-width: 800px;
    margin: 0 auto 32px;
    padding: 24px;
    background: #f0fdf4;
    border-radius: 12px;
  }
  .highlights h3 {
    margin-bottom: 12px;
    color: #166534;
  }
  .highlights ul {
    padding-left: 24px;
    color: #166534;
  }
  .highlights li {
    margin-bottom: 6px;
  }
  .html-work {
    max-width: 800px;
    margin: 0 auto 32px;
  }
  .html-work h3 {
    margin-bottom: 12px;
    color: var(--text-primary);
  }
  .back-btn {
    max-width: 800px;
    margin: 48px auto 0;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  .back-btn a {
    color: var(--accent);
    font-weight: 500;
  }
  @media (max-width: 640px) {
    .detail-header h1 {
      font-size: 1.6rem;
    }
  }
</style>

<script is:inline>
  function autoResizeIframe(iframe) {
    // 自动读取 iframe 内部内容的实际高度
    iframe.style.height =
      iframe.contentWindow.document.documentElement.scrollHeight + "px";
  }
</script>
